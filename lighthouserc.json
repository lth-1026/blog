{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready in|started server on|Local:",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3000/ko",
        "http://localhost:3000/ko/blog/hello-world"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "unused-javascript": ["error", { "maxNumericValue": 204800 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 819200 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 1572864 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
